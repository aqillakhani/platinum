# Copy to secrets/.env and fill in. The .env file is gitignored.

# --- Claude API (story adaptation, scene breakdown, visual prompts) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- YouTube Data API v3 (publisher) ---
# OAuth2 — generate refresh_token via scripts/youtube_auth.py
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# --- vast.ai (cloud GPU for ComfyUI / Wan 2.2 / Chatterbox / Whisper / RealESRGAN) ---
# Long-lived RTX 4090 instance with persistent volume (provisioned by scripts/vast_setup.sh)
VAST_INSTANCE_HOST=                # e.g. ssh4.vast.ai
VAST_INSTANCE_PORT=                # SSH port assigned by vast.ai
VAST_INSTANCE_USER=root
VAST_SSH_KEY_PATH=~/.ssh/vast_key  # private key for SSH to the instance
COMFYUI_HOST=                      # public host:port serving ComfyUI HTTP (e.g. 1.2.3.4:8188)

# --- Optional: Flux.1 Pro API (atmospheric horror keyframes when track config flips to pro_api) ---
BFL_API_KEY=

# --- Optional: ElevenLabs Turbo v3 fallback (voice provider hot-swap) ---
ELEVENLABS_API_KEY=

# --- Session 6.1 keyframe live smoke (per-rental, see docs/runbooks/vast-ai-keyframe-smoke.md) ---
# Set these to point at a freshly-rented vast.ai instance. Override the YAML
# defaults in config/settings.yaml. Leave commented when no instance is rented.
# PLATINUM_COMFYUI_HOST=http://1.2.3.4:8188
# PLATINUM_AESTHETICS_HOST=http://1.2.3.4:8189
