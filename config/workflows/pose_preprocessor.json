{
  "_meta": {
    "title": "DWPose preprocessor (single-output)",
    "session": 7,
    "role": {
      "image_input": "1",
      "preprocessor": "2",
      "image_output": "3"
    }
  },
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "placeholder_prerender.png"
    }
  },
  "2": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["1", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024
    }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "_pose",
      "images": ["2", 0]
    }
  }
}
