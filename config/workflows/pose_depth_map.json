{
  "_meta": {
    "title": "Pose + Depth preprocessor pass",
    "session": 7,
    "role": {
      "image_input": "1",
      "pose_preprocessor": "2",
      "depth_preprocessor": "3",
      "pose_output": "4",
      "depth_output": "5"
    }
  },
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "placeholder_prerender.png"
    }
  },
  "2": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["1", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024
    }
  },
  "3": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {
      "image": ["1", 0],
      "ckpt_name": "depth_anything_v2_vitl.pth",
      "resolution": 1024
    }
  },
  "4": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "_pose",
      "images": ["2", 0]
    }
  },
  "5": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "_depth",
      "images": ["3", 0]
    }
  }
}
