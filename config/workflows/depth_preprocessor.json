{
  "_meta": {
    "title": "DepthAnythingV2 preprocessor (single-output)",
    "session": 7,
    "role": {
      "image_input": "1",
      "preprocessor": "2",
      "image_output": "3"
    }
  },
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "placeholder_prerender.png"
    }
  },
  "2": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {
      "image": ["1", 0],
      "ckpt_name": "depth_anything_v2_vitl.pth",
      "resolution": 1024
    }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "_depth",
      "images": ["2", 0]
    }
  }
}
